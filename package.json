{
  "name": "rehudex",
  "version": "0.2.0",
  "description": "终端 AI 助手 + 工具调用闭环,基于 DeepSeek。流式输出、Markdown 渲染、会话持久化。",
  "keywords": ["ai", "agent", "cli", "deepseek", "repl", "llm"],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "rehudex": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm build"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.2.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "dotenv": "^17.4.2",
    "md4x": "^0.0.25",
    "openai": "^6.39.0",
    "picocolors": "^1.1.1",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
